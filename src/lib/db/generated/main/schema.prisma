datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/db/generated/main"
}

model submission {
  id          Int     @id
  techname    String
  tl1_desc    String
  tl2_desc    String
  tl3_desc    String
  tl4_desc    String
  link        String
  displaytext String
  accepted    Boolean
  username    String
  contact     String

  @@map("submission")
}

model domains {
  id      Int     @id
  R       Boolean
  TP      Boolean
  MT      Boolean
  AR      Boolean
  U       Boolean
  MDL     Boolean
  RA      Boolean
  RoTech  Boolean
  LS      Boolean
  RoThink Boolean
  EoST    Boolean
  EF      Boolean
  RTE     Boolean
  DLoI    Boolean
  RaAoC   Boolean

  @@map("domains")
}

model login {
  User String @id
  PW   String

  @@map("login")
}
