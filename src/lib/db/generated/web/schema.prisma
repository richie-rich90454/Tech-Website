datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/db/generated/web"
}

model twoauthsettings {
  secret String @id

  @@map("2authsettings")
}

model actions {
  id     Int    @id @default(autoincrement())
  admin  String
  client String
  action String
  date   Int

  @@map("actions")
}

model affiliateWithdraws {
  ID             Int    @id @default(autoincrement())
  userID         Int
  withdrawAmount String
  paymentMethod  String
  paymentAddress String
  status         Int    @default(0)
  date           Int

  @@map("affiliateWithdraws")
}

model api {
  id      Int    @id @default(autoincrement())
  name    String
  api     String
  slots   Int
  methods String
  vip     Int

  @@map("api")
}

model bans {
  username String @id
  reason   String

  @@map("bans")
}

model blacklist {
  ID   Int    @id @default(autoincrement())
  data String
  type String

  @@map("blacklist")
}

model cark {
  id   Int     @id @default(autoincrement())
  plan Int     @default(0)
  sans String?

  @@map("cark")
}

model faq {
  id       Int    @id @default(autoincrement())
  question String
  answer   String

  @@map("faq")
}

model fe {
  ID     Int    @id @default(autoincrement())
  userID Int
  type   String
  ip     String

  @@map("fe")
}

model giftcards {
  ID          Int     @id @default(autoincrement())
  code        String
  planID      Int
  claimedby   Int
  dateClaimed Int
  date        Int
  user        String?

  @@map("giftcards")
}

model iplogs {
  ID     Int    @id @default(autoincrement())
  userID Int
  logged String
  date   Int

  @@map("iplogs")
}

model loginlogs {
  id       Int    @id @default(autoincrement())
  username String
  ip       String
  date     Int
  country  String

  @@map("loginlogs")
}

model logs {
  id        Int    @id @default(autoincrement())
  user      String
  ip        String
  time      Int
  method    String
  postdata  String
  mode      String
  ratelimit String
  cookie    String
  date      Int
  chart     String
  stopped   Int    @default(0)
  handler   String
  origin    String

  @@map("logs")
}

model messages {
  messageid Int    @id @default(autoincrement())
  ticketid  Int
  content   String
  sender    String
  date      Int

  @@map("messages")
}

model methods {
  id       Int    @id @default(autoincrement())
  name     String
  fullname String
  type     String
  command  String

  @@map("methods")
}

model news {
  ID      Int    @id @default(autoincrement())
  title   String
  content String
  date    String

  @@map("news")
}

model payments {
  ID    Int    @id @default(autoincrement())
  paid  Float
  plan  Int
  user  Int
  email String
  tid   String
  date  Int

  @@map("payments")
}

model ping_sessions {
  ID        Int    @id @default(autoincrement())
  ping_key  String
  user_id   Int
  ping_ip   String
  ping_port String

  @@map("ping_sessions")
}

model plans {
  ID          Int    @id @default(autoincrement())
  name        String
  vip         Int
  mbt         Int
  unit        String
  length      Int
  price       Float
  concurrents Int
  private     Int

  @@map("plans")
}

model reports {
  id       Int    @id @default(autoincrement())
  username String
  report   String
  date     Int

  @@map("reports")
}

model servers {
  id       Int    @id @default(autoincrement())
  name     String
  ip       String
  password String
  slots    Int
  methods  String

  @@map("servers")
}

model settings {
  sitename        String @id
  stripePubKey    String
  url             String
  description     String
  cooldown        Int
  cooldownTime    Int
  paypal          String
  bitcoin         String
  stripe          Int
  maintaince      String
  rotation        Int    @default(0)
  system          String
  maxattacks      Int
  testboots       Int
  cloudflare      Int
  skype           String
  key             String
  issuerId        String
  coinpayments    String
  ipnSecret       String
  google_site     String
  google_secret   String
  btc_address     String
  secretKey       String
  cbp             Int
  paypal_email    String
  theme           String
  logo            String
  stripeSecretKey String

  @@map("settings")
}

model smtpsettings {
  host     String @id
  auth     String
  username String
  password String
  port     Int

  @@map("smtpsettings")
}

model tickets {
  id       Int    @id @default(autoincrement())
  subject  String
  content  String
  status   String
  username String
  date     Int

  @@map("tickets")
}

model tos {
  archive String

  @@ignore
}

model users {
  ID              Int     @id @default(autoincrement())
  username        String
  password        String
  rank            Int     @default(0)
  membership      Int
  expire          Int
  status          Int
  referral        String
  referralbalance Int     @default(0)
  testattack      Int
  activity        Int     @default(0)
  twoauth         Int     @map("2auth")
  referedBy       Int
  login_ip        String?
  login_useragent String?
  cark            String?
  ban_sbp         String?

  @@map("users")
}
